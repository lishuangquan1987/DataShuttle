<UserControl
    x:Class="DataShuttle.WpfSample.Views.ScriptEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:icons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:DataShuttle.WpfSample.ViewModels"
    d:DataContext="{d:DesignInstance vm:ScriptEditorViewModel}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 左→右 脚本 -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False">
                <TextBlock
                    Margin="8,0"
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Text="左 → 右  拦截脚本" />
                <Button
                    DockPanel.Dock="Right"
                    Margin="4,2"
                    Command="{Binding ClearFromScriptCommand}"
                    Style="{StaticResource ButtonWarning}"
                    ToolTip="恢复默认脚本">
                    <StackPanel Orientation="Horizontal">
                        <icons:MaterialIcon Kind="Restore" />
                        <TextBlock Margin="3,0,0,0" Text="清空" />
                    </StackPanel>
                </Button>
                <Button
                    DockPanel.Dock="Right"
                    Margin="4,2"
                    Command="{Binding TestFromScriptCommand}"
                    Style="{StaticResource ButtonPrimary}"
                    ToolTip="用下方输入测试脚本">
                    <StackPanel Orientation="Horizontal">
                        <icons:MaterialIcon Kind="Play" />
                        <TextBlock Margin="3,0,0,0" Text="测试" />
                    </StackPanel>
                </Button>
            </DockPanel>

            <TextBox
                Grid.Row="1"
                Margin="4,0"
                AcceptsReturn="True"
                FontFamily="Consolas"
                FontSize="12"
                HorizontalScrollBarVisibility="Auto"
                IsEnabled="{Binding DataContext.SelectedItem.ScriptEditorEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                Text="{Binding FromScript, UpdateSourceTrigger=PropertyChanged}"
                VerticalScrollBarVisibility="Auto" />

            <DockPanel Grid.Row="2" Margin="4,4,4,2">
                <TextBlock VerticalAlignment="Center" Text="测试输入 (HEX)：" />
                <TextBox
                    Margin="4,0"
                    hc:InfoElement.Placeholder="如：01 02 03 FF"
                    Text="{Binding FromTestInput, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>

            <TextBox
                Grid.Row="3"
                Margin="4,0,4,4"
                IsReadOnly="True"
                FontFamily="Consolas"
                FontSize="11"
                Foreground="{DynamicResource PrimaryTextBrush}"
                Text="{Binding FromTestResult, Mode=OneWay}"
                TextWrapping="Wrap"
                Visibility="{Binding FromTestResult, Converter={StaticResource String2VisibilityConverter}}" />
        </Grid>

        <GridSplitter
            Grid.Row="1"
            Height="5"
            HorizontalAlignment="Stretch" />

        <!-- 右→左 脚本 -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False">
                <TextBlock
                    Margin="8,0"
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Text="右 → 左  拦截脚本" />
                <Button
                    DockPanel.Dock="Right"
                    Margin="4,2"
                    Command="{Binding ClearToScriptCommand}"
                    Style="{StaticResource ButtonWarning}"
                    ToolTip="恢复默认脚本">
                    <StackPanel Orientation="Horizontal">
                        <icons:MaterialIcon Kind="Restore" />
                        <TextBlock Margin="3,0,0,0" Text="清空" />
                    </StackPanel>
                </Button>
                <Button
                    DockPanel.Dock="Right"
                    Margin="4,2"
                    Command="{Binding TestToScriptCommand}"
                    Style="{StaticResource ButtonPrimary}"
                    ToolTip="用下方输入测试脚本">
                    <StackPanel Orientation="Horizontal">
                        <icons:MaterialIcon Kind="Play" />
                        <TextBlock Margin="3,0,0,0" Text="测试" />
                    </StackPanel>
                </Button>
            </DockPanel>

            <TextBox
                Grid.Row="1"
                Margin="4,0"
                AcceptsReturn="True"
                FontFamily="Consolas"
                FontSize="12"
                HorizontalScrollBarVisibility="Auto"
                IsEnabled="{Binding DataContext.SelectedItem.ScriptEditorEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                Text="{Binding ToScript, UpdateSourceTrigger=PropertyChanged}"
                VerticalScrollBarVisibility="Auto" />

            <DockPanel Grid.Row="2" Margin="4,4,4,2">
                <TextBlock VerticalAlignment="Center" Text="测试输入 (HEX)：" />
                <TextBox
                    Margin="4,0"
                    hc:InfoElement.Placeholder="如：01 02 03 FF"
                    Text="{Binding ToTestInput, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>

            <TextBox
                Grid.Row="3"
                Margin="4,0,4,4"
                IsReadOnly="True"
                FontFamily="Consolas"
                FontSize="11"
                Foreground="{DynamicResource PrimaryTextBrush}"
                Text="{Binding ToTestResult, Mode=OneWay}"
                TextWrapping="Wrap"
                Visibility="{Binding ToTestResult, Converter={StaticResource String2VisibilityConverter}}" />
        </Grid>
    </Grid>
</UserControl>
