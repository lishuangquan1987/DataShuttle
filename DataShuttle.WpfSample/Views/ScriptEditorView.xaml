<UserControl
    x:Class="DataShuttle.WpfSample.Views.ScriptEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:icons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:DataShuttle.WpfSample.ViewModels"
    d:DataContext="{d:DesignInstance vm:ScriptEditorViewModel}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 左→右 脚本 -->
        <Border Grid.Row="0" Background="#FFF3E0" CornerRadius="4" Margin="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#FFE0B2" CornerRadius="4,4,0,0">
                    <DockPanel Margin="8,0">
                        <TextBlock VerticalAlignment="Center" FontWeight="Bold"
                            Foreground="#E65100" Text="左 → 右  拦截脚本" />
                        <Button DockPanel.Dock="Right" Height="20" Padding="6,0"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="#E65100" Foreground="White" BorderThickness="0"
                            Cursor="Hand" ToolTip="在专业编辑器中打开"
                            IsEnabled="{Binding DataContext.SelectedItem.ScriptEditorEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                            Click="EditFromScript_Click">
                            <StackPanel Orientation="Horizontal">
                                <icons:MaterialIcon Kind="Pencil" Width="11" Height="11" VerticalAlignment="Center"/>
                                <TextBlock Text="编辑" Margin="3,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </DockPanel>
                </Border>
                <TextBox Grid.Row="1" Margin="4"
                    AcceptsReturn="True" FontFamily="Consolas" FontSize="12"
                    HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                    IsEnabled="{Binding DataContext.SelectedItem.ScriptEditorEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                    Text="{Binding FromScript, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </Border>

        <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" />

        <!-- 右→左 脚本 -->
        <Border Grid.Row="2" Background="#E8F5E9" CornerRadius="4" Margin="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#C8E6C9" CornerRadius="4,4,0,0">
                    <DockPanel Margin="8,0">
                        <TextBlock VerticalAlignment="Center" FontWeight="Bold"
                            Foreground="#1B5E20" Text="右 → 左  拦截脚本" />
                        <Button DockPanel.Dock="Right" Height="20" Padding="6,0"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="#2E7D32" Foreground="White" BorderThickness="0"
                            Cursor="Hand" ToolTip="在专业编辑器中打开"
                            IsEnabled="{Binding DataContext.SelectedItem.ScriptEditorEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                            Click="EditToScript_Click">
                            <StackPanel Orientation="Horizontal">
                                <icons:MaterialIcon Kind="Pencil" Width="11" Height="11" VerticalAlignment="Center"/>
                                <TextBlock Text="编辑" Margin="3,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </DockPanel>
                </Border>
                <TextBox Grid.Row="1" Margin="4"
                    AcceptsReturn="True" FontFamily="Consolas" FontSize="12"
                    HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                    IsEnabled="{Binding DataContext.SelectedItem.ScriptEditorEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                    Text="{Binding ToScript, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
