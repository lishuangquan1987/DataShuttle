<hc:Window
    x:Class="DataShuttle.WpfSample.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:icons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:DataShuttle.WpfSample.Views"
    xmlns:vm="clr-namespace:DataShuttle.WpfSample.ViewModels"
    Title="数据穿梭"
    Width="1000"
    Height="660"
    d:DataContext="{d:DesignInstance vm:MainWindowViewModel}"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" MinWidth="160" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== 左侧：列表 ===== -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Height="32" Margin="8,6" HorizontalAlignment="Left"
                Command="{Binding AddItemCommand}" Style="{StaticResource ButtonPrimary}">
                <StackPanel Orientation="Horizontal">
                    <icons:MaterialIcon VerticalAlignment="Center" Kind="Add" />
                    <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" Text="添加" />
                </StackPanel>
            </Button>

            <ListBox Grid.Row="1"
                ItemsSource="{Binding Items}"
                SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="6,4" />
                        <Setter Property="Foreground" Value="#333333" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#1565C0" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#BBDEFB" />
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsSelected" Value="True" />
                                                <Condition Property="IsMouseOver" Value="True" />
                                            </MultiTrigger.Conditions>
                                            <Setter Property="Background" Value="#0D47A1" />
                                            <Setter Property="Foreground" Value="White" />
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ShuttleLineItemViewModel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- 名称 + 编辑/删除 -->
                            <DockPanel Grid.Row="0" LastChildFill="True">
                                <Button DockPanel.Dock="Right" Width="22" Height="22" Padding="0"
                                    Margin="2,0,0,0"
                                    Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource ButtonDanger}"
                                    IsEnabled="{Binding ScriptEditorEnabled}">
                                    <icons:MaterialIcon Kind="Delete" Width="12" Height="12" />
                                </Button>
                                <Button DockPanel.Dock="Right" Width="22" Height="22" Padding="0"
                                    Margin="2,0,0,0"
                                    Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource ButtonInfo}"
                                    IsEnabled="{Binding ScriptEditorEnabled}">
                                    <icons:MaterialIcon Kind="Pencil" Width="12" Height="12" />
                                </Button>
                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                    Text="{Binding Config.Name}" TextTrimming="CharacterEllipsis"
                                    VerticalAlignment="Center" />
                            </DockPanel>

                            <!-- From -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Margin="0,0,5,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#CCC" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FromIsConnected}" Value="True">
                                                    <Setter Property="Fill" Value="#4CAF50" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock FontSize="12" Text="{Binding FromSummary}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <icons:MaterialIcon Grid.Row="2" Margin="13,1" FontSize="14"
                                Foreground="{DynamicResource PrimaryBrush}" Kind="ArrowUpDown" />

                            <!-- To -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Margin="0,0,5,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#CCC" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ToIsConnected}" Value="True">
                                                    <Setter Property="Fill" Value="#4CAF50" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock FontSize="12" Text="{Binding ToSummary}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" />

        <!-- ===== 右侧 ===== -->
        <Grid Grid.Column="2">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                Foreground="{DynamicResource SecondaryTextBrush}"
                Text="← 请在左侧选择一条穿梭线"
                Visibility="{Binding HasSelection, Converter={StaticResource Boolean2VisibilityReConverter}}" />

            <Grid Visibility="{Binding HasSelection, Converter={StaticResource Boolean2VisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="200" MinHeight="160" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 运行状态面板 -->
                <Border Grid.Row="0" Margin="8,8,8,0"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                    <Grid Margin="12,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,2" Orientation="Horizontal">
                            <TextBlock Width="36" VerticalAlignment="Center" Text="左端：" />
                            <TextBlock Margin="4,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding SelectedItem.FromSummary}" />
                            <Ellipse Width="10" Height="10" Margin="8,0,4,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#CCC" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem.FromIsConnected}" Value="True">
                                                <Setter Property="Fill" Value="#4CAF50" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock VerticalAlignment="Center" Text="{Binding SelectedItem.FromStatusText}" />
                            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center"
                                Foreground="{DynamicResource SecondaryTextBrush}"
                                Text="{Binding SelectedItem.FromTrafficText}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,2" Orientation="Horizontal">
                            <TextBlock Width="36" VerticalAlignment="Center" Text="右端：" />
                            <TextBlock Margin="4,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding SelectedItem.ToSummary}" />
                            <Ellipse Width="10" Height="10" Margin="8,0,4,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#CCC" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem.ToIsConnected}" Value="True">
                                                <Setter Property="Fill" Value="#4CAF50" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock VerticalAlignment="Center" Text="{Binding SelectedItem.ToStatusText}" />
                            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center"
                                Foreground="{DynamicResource SecondaryTextBrush}"
                                Text="{Binding SelectedItem.ToTrafficText}" />
                        </StackPanel>

                        <ListBox x:Name="LogListBox" Grid.Row="2" Margin="0,4"
                            FontFamily="Consolas" FontSize="11" Foreground="#E53935"
                            ItemsSource="{Binding SelectedItem.Logs}"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            VirtualizingPanel.ScrollUnit="Pixel" />

                        <StackPanel Grid.Row="3" HorizontalAlignment="Left" Orientation="Horizontal">
                            <Button Margin="0,0,8,0" Command="{Binding SelectedItem.StartCmd}" Style="{StaticResource ButtonSuccess}">
                                <StackPanel Orientation="Horizontal">
                                    <icons:MaterialIcon Kind="Play" />
                                    <TextBlock Margin="4,0,0,0" Text="启动" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SelectedItem.StopCmd}" Style="{StaticResource ButtonDanger}">
                                <StackPanel Orientation="Horizontal">
                                    <icons:MaterialIcon Kind="Stop" />
                                    <TextBlock Margin="4,0,0,0" Text="停止" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

                <Border Grid.Row="2" Margin="8,0,8,8"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                    <views:ScriptEditorView Margin="4" DataContext="{Binding ScriptEditor}" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</hc:Window>
