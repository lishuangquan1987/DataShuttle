<hc:Window
    x:Class="DataShuttle.WpfSample.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:icons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:DataShuttle.WpfSample.Views"
    xmlns:vm="clr-namespace:DataShuttle.WpfSample.ViewModels"
    Title="DataShuttle"
    Width="1100" Height="700" MinWidth="800" MinHeight="500"
    d:DataContext="{d:DesignInstance vm:MainWindowViewModel}"
    mc:Ignorable="d">

    <hc:Window.Resources>
        <!-- 日志级别颜色转换 -->
        <Style x:Key="LogRowStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </hc:Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="180"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════ 左侧面板 ═══════════════ -->
        <Border Grid.Column="0" Background="#F5F7FA" BorderBrush="#E0E4EA" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 顶栏 -->
                <Border Grid.Row="0" Background="#1565C0" Padding="10,0">
                    <DockPanel>
                        <icons:MaterialIcon Kind="SwapHorizontal" Foreground="White"
                            Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="穿梭线管理" Foreground="White" FontSize="14"
                            FontWeight="SemiBold" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                        <Button DockPanel.Dock="Right" Height="28" Padding="10,0"
                            Command="{Binding AddItemCommand}"
                            Style="{StaticResource ButtonPrimary}"
                            Background="#0D47A1" BorderThickness="0"
                            ToolTip="新建穿梭线">
                            <StackPanel Orientation="Horizontal">
                                <icons:MaterialIcon Kind="Plus" Width="14" Height="14" VerticalAlignment="Center"/>
                                <TextBlock Text="新建" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </DockPanel>
                </Border>

                <!-- 列表 -->
                <ListBox Grid.Row="1"
                    ItemsSource="{Binding Items}"
                    SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                    Background="Transparent" BorderThickness="0"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    Padding="6,6,6,6">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,3"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ShuttleLineItemViewModel}">
                            <Border x:Name="Card" CornerRadius="6" Padding="10,8"
                                Background="White" Cursor="Hand"
                                BorderThickness="1.5" BorderBrush="#E0E4EA">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000" Opacity="0.06" BlurRadius="6" ShadowDepth="1"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="2"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="2"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- 名称行 + 操作按钮 -->
                                    <DockPanel Grid.Row="0">
                                        <!-- 运行状态指示点 -->
                                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#9E9E9E"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <Setter Property="Fill" Value="#43A047"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                                            Text="{Binding Config.Name}" TextTrimming="CharacterEllipsis"
                                            Foreground="#1A237E"/>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Width="22" Height="22" Padding="0" Margin="2,0,0,0"
                                                Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ButtonInfo}"
                                                IsEnabled="{Binding ScriptEditorEnabled}"
                                                ToolTip="编辑配置">
                                                <icons:MaterialIcon Kind="Pencil" Width="11" Height="11"/>
                                            </Button>
                                            <Button Width="22" Height="22" Padding="0" Margin="2,0,0,0"
                                                Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ButtonDanger}"
                                                IsEnabled="{Binding ScriptEditorEnabled}"
                                                ToolTip="删除">
                                                <icons:MaterialIcon Kind="Delete" Width="11" Height="11"/>
                                            </Button>
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- 分隔线 -->
                                    <Separator Grid.Row="1" Background="#F0F0F0" Margin="-10,0"/>

                                    <!-- From 端 -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,5,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#BDBDBD"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FromIsConnected}" Value="True">
                                                            <Setter Property="Fill" Value="#43A047"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock FontSize="11" Foreground="#555"
                                            Text="{Binding FromSummary}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- 箭头 -->
                                    <icons:MaterialIcon Grid.Row="4" Kind="ArrowDownThin"
                                        Width="12" Height="12" Margin="0" Foreground="#90A4AE"
                                        HorizontalAlignment="Left"/>

                                    <!-- To 端 -->
                                    <StackPanel Grid.Row="6" Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,5,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#BDBDBD"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ToIsConnected}" Value="True">
                                                            <Setter Property="Fill" Value="#43A047"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock FontSize="11" Foreground="#555"
                                            Text="{Binding ToSummary}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>

                                <!-- 选中/悬停效果 -->
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderBrush" Value="#E0E4EA"/>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="Card" Property="BorderBrush" Value="#1565C0"/>
                                    <Setter TargetName="Card" Property="Background" Value="#E8F0FE"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#E0E4EA"/>

        <!-- ═══════════════ 右侧面板 ═══════════════ -->
        <Grid Grid.Column="2" Background="#FAFBFC">

            <!-- 空状态提示 -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                Visibility="{Binding HasSelection, Converter={StaticResource Boolean2VisibilityReConverter}}">
                <icons:MaterialIcon Kind="SwapHorizontal" Width="48" Height="48"
                    Foreground="#CFD8DC" HorizontalAlignment="Center"/>
                <TextBlock Text="请在左侧选择一条穿梭线" Margin="0,12,0,0"
                    Foreground="#B0BEC5" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- 详情区 -->
            <Grid Visibility="{Binding HasSelection, Converter={StaticResource Boolean2VisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="*" MinHeight="200"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="220" MinHeight="140"/>
                </Grid.RowDefinitions>

                <!-- 顶部标题栏 -->
                <Border Grid.Row="0" Background="#1565C0" Padding="14,0">
                    <DockPanel>
                        <TextBlock Text="{Binding SelectedItem.Config.Name}"
                            Foreground="White" FontSize="14" FontWeight="SemiBold"
                            VerticalAlignment="Center"/>
                        <!-- 运行状态 badge -->
                        <Border DockPanel.Dock="Left" Margin="12,0,0,0" CornerRadius="10"
                            Padding="8,2" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#9E9E9E"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedItem.IsRunning}" Value="True">
                                            <Setter Property="Background" Value="#43A047"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding SelectedItem.RunningStatusText}"
                                Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                        <!-- 操作按钮 -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Height="30" Padding="12,0" Margin="0,0,8,0"
                                Command="{Binding SelectedItem.StartCmd}"
                                Style="{StaticResource ButtonSuccess}"
                                ToolTip="启动穿梭线">
                                <StackPanel Orientation="Horizontal">
                                    <icons:MaterialIcon Kind="Play" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="启动" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Height="30" Padding="12,0"
                                Command="{Binding SelectedItem.StopCmd}"
                                Style="{StaticResource ButtonDanger}"
                                ToolTip="停止穿梭线">
                                <StackPanel Orientation="Horizontal">
                                    <icons:MaterialIcon Kind="Stop" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="停止" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- 状态 + 日志区 -->
                <Grid Grid.Row="1" Margin="12,10,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左：端点状态卡片 -->
                    <StackPanel Grid.Column="0" Orientation="Vertical">

                        <!-- From 卡片 -->
                        <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,8"
                            Background="White" BorderBrush="#E0E4EA" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" Opacity="0.05" BlurRadius="4" ShadowDepth="1"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <Border CornerRadius="3" Padding="4,1" Background="#E3F2FD" Margin="0,0,6,0">
                                        <TextBlock Text="左端" FontSize="10" FontWeight="Bold" Foreground="#1565C0"/>
                                    </Border>
                                    <TextBlock FontSize="11" Foreground="#555" VerticalAlignment="Center"
                                        Text="{Binding SelectedItem.FromSummary}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Separator Grid.Row="1" Background="#F0F0F0"/>
                                <StackPanel Grid.Row="2" Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#BDBDBD"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedItem.FromIsConnected}" Value="True">
                                                        <Setter Property="Fill" Value="#43A047"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock FontSize="12" VerticalAlignment="Center"
                                        Text="{Binding SelectedItem.FromStatusText}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="4" Orientation="Horizontal">
                                    <icons:MaterialIcon Kind="ArrowUp" Width="12" Height="12"
                                        Foreground="#78909C" VerticalAlignment="Center"/>
                                    <TextBlock FontSize="11" Foreground="#78909C" Margin="3,0,0,0"
                                        Text="{Binding SelectedItem.FromTrafficText}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 双向箭头 -->
                        <icons:MaterialIcon Kind="ArrowUpDown" Width="20" Height="20"
                            Foreground="#90A4AE" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                        <!-- To 卡片 -->
                        <Border CornerRadius="6" Padding="12,10"
                            Background="White" BorderBrush="#E0E4EA" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" Opacity="0.05" BlurRadius="4" ShadowDepth="1"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <Border CornerRadius="3" Padding="4,1" Background="#E8F5E9" Margin="0,0,6,0">
                                        <TextBlock Text="右端" FontSize="10" FontWeight="Bold" Foreground="#2E7D32"/>
                                    </Border>
                                    <TextBlock FontSize="11" Foreground="#555" VerticalAlignment="Center"
                                        Text="{Binding SelectedItem.ToSummary}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Separator Grid.Row="1" Background="#F0F0F0"/>
                                <StackPanel Grid.Row="2" Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#BDBDBD"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedItem.ToIsConnected}" Value="True">
                                                        <Setter Property="Fill" Value="#43A047"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock FontSize="12" VerticalAlignment="Center"
                                        Text="{Binding SelectedItem.ToStatusText}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="4" Orientation="Horizontal">
                                    <icons:MaterialIcon Kind="ArrowDown" Width="12" Height="12"
                                        Foreground="#78909C" VerticalAlignment="Center"/>
                                    <TextBlock FontSize="11" Foreground="#78909C" Margin="3,0,0,0"
                                        Text="{Binding SelectedItem.ToTrafficText}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- 右：日志面板 -->
                    <Border Grid.Column="2" CornerRadius="6" Background="#1E1E2E"
                        BorderBrush="#2D2D3F" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 日志标题栏 -->
                            <Border Grid.Row="0" Background="#2D2D3F" CornerRadius="6,6,0,0" Padding="10,0">
                                <DockPanel>
                                    <icons:MaterialIcon Kind="Console" Width="14" Height="14"
                                        Foreground="#90A4AE" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="运行日志" Foreground="#90A4AE" FontSize="12"
                                        VerticalAlignment="Center"/>
                                    <TextBlock DockPanel.Dock="Right" Foreground="#546E7A" FontSize="10"
                                        VerticalAlignment="Center" HorizontalAlignment="Right"
                                        Text="{Binding SelectedItem.Logs.Count, StringFormat='共 {0} 条'}"/>
                                </DockPanel>
                            </Border>

                            <!-- 日志列表 -->
                            <ListBox x:Name="LogListBox" Grid.Row="1"
                                ItemsSource="{Binding SelectedItem.Logs}"
                                Background="Transparent" BorderThickness="0"
                                ItemContainerStyle="{StaticResource LogRowStyle}"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                VirtualizingPanel.ScrollUnit="Pixel"
                                VirtualizingPanel.IsVirtualizing="True"
                                Padding="4,4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:LogEntry}">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left" Text="{Binding Time}"
                                                FontFamily="Consolas" FontSize="11"
                                                Foreground="#546E7A" Margin="0,0,6,0" VerticalAlignment="Top"/>
                                            <Border DockPanel.Dock="Left" CornerRadius="2" Padding="3,0"
                                                Margin="0,0,6,0" VerticalAlignment="Top">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1E88E5"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                <Setter Property="Background" Value="#F57C00"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                <Setter Property="Background" Value="#C62828"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding LevelTag}"
                                                    FontFamily="Consolas" FontSize="10"
                                                    FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                            <TextBlock Text="{Binding Message}"
                                                FontFamily="Consolas" FontSize="11"
                                                TextWrapping="Wrap" VerticalAlignment="Top">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#B0BEC5"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                <Setter Property="Foreground" Value="#FFB74D"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                <Setter Property="Foreground" Value="#EF9A9A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>

                <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch"
                    Background="#E0E4EA" VerticalAlignment="Stretch"/>

                <!-- 脚本编辑区 -->
                <Border Grid.Row="3" Margin="12,0,12,10"
                    CornerRadius="6" Background="White"
                    BorderBrush="#E0E4EA" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.04" BlurRadius="4" ShadowDepth="1"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#F5F7FA" CornerRadius="6,6,0,0"
                            BorderBrush="#E0E4EA" BorderThickness="0,0,0,1" Padding="10,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <icons:MaterialIcon Kind="CodeBraces" Width="14" Height="14"
                                    Foreground="#78909C" Margin="0,0,6,0"/>
                                <TextBlock Text="数据拦截脚本 (Lua)" Foreground="#546E7A" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <views:ScriptEditorView Grid.Row="1" Margin="4" DataContext="{Binding ScriptEditor}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</hc:Window>
