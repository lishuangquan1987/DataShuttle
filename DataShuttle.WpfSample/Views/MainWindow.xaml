<hc:Window
    x:Class="DataShuttle.WpfSample.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:icons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:DataShuttle.WpfSample.Views"
    xmlns:vm="clr-namespace:DataShuttle.WpfSample.ViewModels"
    Title="DataShuttle"
    Width="1100"
    Height="700"
    MinWidth="800"
    MinHeight="500"
    d:DataContext="{d:DesignInstance vm:MainWindowViewModel}"
    mc:Ignorable="d">

    <hc:Window.Resources>
        <!--  日志级别颜色转换  -->
        <Style x:Key="LogRowStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A000000" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </hc:Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="180" />
            <ColumnDefinition Width="4" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  ═══════════════ 左侧面板 ═══════════════  -->
        <Border
            Grid.Column="0"
            Background="#F5F7FA"
            BorderBrush="#E0E4EA"
            BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  顶栏  -->
                <Border
                    Grid.Row="0"
                    Padding="10,0"
                    Background="#1565C0">
                    <DockPanel>
                        <icons:MaterialIcon
                            Width="20"
                            Height="20"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Kind="SwapHorizontal" />
                        <TextBlock
                            VerticalAlignment="Center"
                            DockPanel.Dock="Left"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="穿梭线管理" />
                        <Button
                            Height="28"
                            Padding="10,0"
                            Background="#0D47A1"
                            BorderThickness="0"
                            Command="{Binding AddItemCommand}"
                            DockPanel.Dock="Right"
                            Style="{StaticResource ButtonPrimary}"
                            ToolTip="新建穿梭线">
                            <StackPanel Orientation="Horizontal">
                                <icons:MaterialIcon
                                    Width="14"
                                    Height="14"
                                    VerticalAlignment="Center"
                                    Kind="Plus" />
                                <TextBlock
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Text="新建" />
                            </StackPanel>
                        </Button>
                    </DockPanel>
                </Border>

                <!--  列表  -->
                <ListBox
                    Grid.Row="1"
                    Padding="6,6,6,6"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding Items}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,3" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ShuttleLineItemViewModel}">
                            <Border
                                x:Name="Card"
                                Padding="10,8"
                                Background="White"
                                BorderBrush="#E0E4EA"
                                BorderThickness="1.5"
                                CornerRadius="6"
                                Cursor="Hand">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="6"
                                        Opacity="0.06"
                                        ShadowDepth="1"
                                        Color="#000" />
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="6" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="2" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="2" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!--  名称行 + 操作按钮  -->
                                    <DockPanel Grid.Row="0">
                                        <!--  运行状态指示点  -->
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#9E9E9E" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <Setter Property="Fill" Value="#43A047" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="#1A237E"
                                            Text="{Binding Config.Name}"
                                            TextTrimming="CharacterEllipsis" />
                                        <StackPanel
                                            HorizontalAlignment="Right"
                                            DockPanel.Dock="Right"
                                            Orientation="Horizontal">
                                            <Button
                                                Width="22"
                                                Height="22"
                                                Margin="2,0,0,0"
                                                Padding="0"
                                                Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding ScriptEditorEnabled}"
                                                Style="{StaticResource ButtonInfo}"
                                                ToolTip="编辑配置">
                                                <icons:MaterialIcon
                                                    Width="11"
                                                    Height="11"
                                                    Kind="Pencil" />
                                            </Button>
                                            <Button
                                                Width="22"
                                                Height="22"
                                                Margin="2,0,0,0"
                                                Padding="0"
                                                Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding ScriptEditorEnabled}"
                                                Style="{StaticResource ButtonDanger}"
                                                ToolTip="删除">
                                                <icons:MaterialIcon
                                                    Width="11"
                                                    Height="11"
                                                    Kind="Delete" />
                                            </Button>
                                        </StackPanel>
                                    </DockPanel>

                                    <!--  分隔线  -->
                                    <Separator
                                        Grid.Row="1"
                                        Margin="-10,0"
                                        Background="#F0F0F0" />

                                    <!--  From 端  -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                        <Ellipse
                                            Width="7"
                                            Height="7"
                                            Margin="0,0,5,0"
                                            VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#BDBDBD" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FromIsConnected}" Value="True">
                                                            <Setter Property="Fill" Value="#43A047" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="#555"
                                            Text="{Binding FromSummary}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <!--  箭头  -->
                                    <icons:MaterialIcon
                                        Grid.Row="4"
                                        Width="12"
                                        Height="12"
                                        Margin="0"
                                        HorizontalAlignment="Left"
                                        Foreground="#90A4AE"
                                        Kind="ArrowDownThin" />

                                    <!--  To 端  -->
                                    <StackPanel Grid.Row="6" Orientation="Horizontal">
                                        <Ellipse
                                            Width="7"
                                            Height="7"
                                            Margin="0,0,5,0"
                                            VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#BDBDBD" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ToIsConnected}" Value="True">
                                                            <Setter Property="Fill" Value="#43A047" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="#555"
                                            Text="{Binding ToSummary}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>

                                <!--  选中/悬停效果  -->
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="White" />
                                        <Setter Property="BorderBrush" Value="#E0E4EA" />
                                    </Style>
                                </Border.Style>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="Card" Property="BorderBrush" Value="#1565C0" />
                                    <Setter TargetName="Card" Property="Background" Value="#E8F0FE" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <GridSplitter
            Grid.Column="1"
            Width="4"
            HorizontalAlignment="Stretch"
            Background="#E0E4EA" />

        <!--  ═══════════════ 右侧面板 ═══════════════  -->
        <Grid Grid.Column="2" Background="#FAFBFC">

            <!--  空状态提示  -->
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding HasSelection, Converter={StaticResource Boolean2VisibilityReConverter}}">
                <icons:MaterialIcon
                    Width="48"
                    Height="48"
                    HorizontalAlignment="Center"
                    Foreground="#CFD8DC"
                    Kind="SwapHorizontal" />
                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    Foreground="#B0BEC5"
                    Text="请在左侧选择一条穿梭线" />
            </StackPanel>

            <!--  详情区  -->
            <Grid Visibility="{Binding HasSelection, Converter={StaticResource Boolean2VisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="210" MinHeight="210" />
                    <RowDefinition Height="4" />
                    <RowDefinition Height="*" MinHeight="140" />
                </Grid.RowDefinitions>

                <!--  顶部标题栏  -->
                <Border
                    Grid.Row="0"
                    Padding="14,0"
                    Background="#1565C0">
                    <DockPanel>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="{Binding SelectedItem.Config.Name}" />
                        <!--  运行状态 badge  -->
                        <Border
                            Margin="12,0,0,0"
                            Padding="8,2"
                            VerticalAlignment="Center"
                            CornerRadius="10"
                            DockPanel.Dock="Left">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#9E9E9E" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedItem.IsRunning}" Value="True">
                                            <Setter Property="Background" Value="#43A047" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="{Binding SelectedItem.RunningStatusText}" />
                        </Border>
                        <!--  操作按钮  -->
                        <StackPanel
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right"
                            Orientation="Horizontal">
                            <Button
                                Height="30"
                                Margin="0,0,8,0"
                                Padding="12,0"
                                Command="{Binding SelectedItem.StartCmd}"
                                Style="{StaticResource ButtonSuccess}"
                                ToolTip="启动穿梭线">
                                <StackPanel Orientation="Horizontal">
                                    <icons:MaterialIcon
                                        Width="14"
                                        Height="14"
                                        VerticalAlignment="Center"
                                        Kind="Play" />
                                    <TextBlock
                                        Margin="5,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="启动" />
                                </StackPanel>
                            </Button>
                            <Button
                                Height="30"
                                Padding="12,0"
                                Command="{Binding SelectedItem.StopCmd}"
                                Style="{StaticResource ButtonDanger}"
                                ToolTip="停止穿梭线">
                                <StackPanel Orientation="Horizontal">
                                    <icons:MaterialIcon
                                        Width="14"
                                        Height="14"
                                        VerticalAlignment="Center"
                                        Kind="Stop" />
                                    <TextBlock
                                        Margin="5,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="停止" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!--  状态 + 日志区  -->
                <Grid Grid.Row="1" Margin="12,10,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  左：端点状态卡片  -->
                    <StackPanel Grid.Column="0" Orientation="Vertical">

                        <!--  From 卡片  -->
                        <Border
                            Margin="0,0,0,8"
                            Padding="12,10"
                            Background="White"
                            BorderBrush="#E0E4EA"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="4"
                                    Opacity="0.05"
                                    ShadowDepth="1"
                                    Color="#000" />
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <Border
                                        Margin="0,0,6,0"
                                        Padding="4,1"
                                        Background="#E3F2FD"
                                        CornerRadius="3">
                                        <TextBlock
                                            FontSize="10"
                                            FontWeight="Bold"
                                            Foreground="#1565C0"
                                            Text="左端" />
                                    </Border>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="#555"
                                        Text="{Binding SelectedItem.FromSummary}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Separator Grid.Row="1" Background="#F0F0F0" />
                                <StackPanel Grid.Row="2" Orientation="Horizontal">
                                    <Ellipse
                                        Width="8"
                                        Height="8"
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#BDBDBD" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedItem.FromIsConnected}" Value="True">
                                                        <Setter Property="Fill" Value="#43A047" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Text="{Binding SelectedItem.FromStatusText}" />
                                </StackPanel>
                                <StackPanel Grid.Row="4" Orientation="Horizontal">
                                    <icons:MaterialIcon
                                        Width="12"
                                        Height="12"
                                        VerticalAlignment="Center"
                                        Foreground="#78909C"
                                        Kind="ArrowUp" />
                                    <TextBlock
                                        Margin="3,0,0,0"
                                        FontSize="11"
                                        Foreground="#78909C"
                                        Text="{Binding SelectedItem.FromTrafficText}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!--  双向箭头  -->
                        <icons:MaterialIcon
                            Width="20"
                            Height="20"
                            Margin="0,0,0,8"
                            HorizontalAlignment="Center"
                            Foreground="#90A4AE"
                            Kind="ArrowUpDown" />

                        <!--  To 卡片  -->
                        <Border
                            Padding="12,10"
                            Background="White"
                            BorderBrush="#E0E4EA"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="4"
                                    Opacity="0.05"
                                    ShadowDepth="1"
                                    Color="#000" />
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <Border
                                        Margin="0,0,6,0"
                                        Padding="4,1"
                                        Background="#E8F5E9"
                                        CornerRadius="3">
                                        <TextBlock
                                            FontSize="10"
                                            FontWeight="Bold"
                                            Foreground="#2E7D32"
                                            Text="右端" />
                                    </Border>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="#555"
                                        Text="{Binding SelectedItem.ToSummary}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Separator Grid.Row="1" Background="#F0F0F0" />
                                <StackPanel Grid.Row="2" Orientation="Horizontal">
                                    <Ellipse
                                        Width="8"
                                        Height="8"
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#BDBDBD" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedItem.ToIsConnected}" Value="True">
                                                        <Setter Property="Fill" Value="#43A047" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Text="{Binding SelectedItem.ToStatusText}" />
                                </StackPanel>
                                <StackPanel Grid.Row="4" Orientation="Horizontal">
                                    <icons:MaterialIcon
                                        Width="12"
                                        Height="12"
                                        VerticalAlignment="Center"
                                        Foreground="#78909C"
                                        Kind="ArrowDown" />
                                    <TextBlock
                                        Margin="3,0,0,0"
                                        FontSize="11"
                                        Foreground="#78909C"
                                        Text="{Binding SelectedItem.ToTrafficText}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!--  右：日志面板  -->
                    <Border
                        Grid.Column="2"
                        Background="#1E1E2E"
                        BorderBrush="#2D2D3F"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  日志标题栏  -->
                            <Border
                                Grid.Row="0"
                                Padding="10,0"
                                Background="#2D2D3F"
                                CornerRadius="6,6,0,0">
                                <DockPanel>
                                    <icons:MaterialIcon
                                        Width="14"
                                        Height="14"
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        Foreground="#90A4AE"
                                        Kind="Console" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="#90A4AE"
                                        Text="运行日志" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        DockPanel.Dock="Right"
                                        FontSize="10"
                                        Foreground="#546E7A"
                                        Text="{Binding SelectedItem.Logs.Count, StringFormat='共 {0} 条'}" />
                                </DockPanel>
                            </Border>

                            <!--  日志列表  -->
                            <ListBox
                                x:Name="LogListBox"
                                Grid.Row="1"
                                Padding="4,4"
                                Background="Transparent"
                                BorderThickness="0"
                                ItemContainerStyle="{StaticResource LogRowStyle}"
                                ItemsSource="{Binding SelectedItem.Logs}"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                VirtualizingPanel.IsVirtualizing="True"
                                VirtualizingPanel.ScrollUnit="Pixel">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:LogEntry}">
                                        <DockPanel>
                                            <TextBlock
                                                Margin="0,0,6,0"
                                                VerticalAlignment="Top"
                                                DockPanel.Dock="Left"
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                Foreground="#546E7A"
                                                Text="{Binding Time}" />
                                            <Border
                                                Margin="0,0,6,0"
                                                Padding="3,0"
                                                VerticalAlignment="Top"
                                                CornerRadius="2"
                                                DockPanel.Dock="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1E88E5" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                <Setter Property="Background" Value="#F57C00" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                <Setter Property="Background" Value="#C62828" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock
                                                    FontFamily="Consolas"
                                                    FontSize="10"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    Text="{Binding LevelTag}" />
                                            </Border>
                                            <TextBlock
                                                VerticalAlignment="Top"
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                Text="{Binding Message}"
                                                TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#B0BEC5" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                <Setter Property="Foreground" Value="#FFB74D" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                <Setter Property="Foreground" Value="#EF9A9A" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>

                <GridSplitter
                    Grid.Row="2"
                    Height="4"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="#E0E4EA" />

                <!--  脚本编辑区  -->
                <Border
                    Grid.Row="3"
                    Margin="12,0,12,10"
                    Background="White"
                    BorderBrush="#E0E4EA"
                    BorderThickness="1"
                    CornerRadius="6">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="4"
                            Opacity="0.04"
                            ShadowDepth="1"
                            Color="#000" />
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border
                            Grid.Row="0"
                            Padding="10,0"
                            Background="#F5F7FA"
                            BorderBrush="#E0E4EA"
                            BorderThickness="0,0,0,1"
                            CornerRadius="6,6,0,0">
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <icons:MaterialIcon
                                    Width="14"
                                    Height="14"
                                    Margin="0,0,6,0"
                                    Foreground="#78909C"
                                    Kind="CodeBraces" />
                                <TextBlock
