<Window
    x:Class="DataShuttle.WpfSample.Views.LuaEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:icons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    Title="Lua 脚本编辑器"
    Width="780" Height="580"
    MinWidth="600" MinHeight="400"
    WindowStartupLocation="CenterOwner"
    Background="#1E1E2E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="130"/>
            <RowDefinition Height="44"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#2D2D3F" Padding="14,0">
            <DockPanel>
                <icons:MaterialIcon Kind="CodeBraces" Width="16" Height="16"
                    Foreground="#4EC9B0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="TitleText" Foreground="#CDD6F4" FontSize="13"
                    FontWeight="SemiBold" VerticalAlignment="Center"/>
                <!-- 工具按钮 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnTest" Height="26" Padding="10,0" Margin="0,0,8,0"
                        Click="BtnTest_Click"
                        Background="#1E88E5" Foreground="White" BorderThickness="0"
                        Cursor="Hand" ToolTip="运行测试 (F5)">
                        <StackPanel Orientation="Horizontal">
                            <icons:MaterialIcon Kind="Play" Width="13" Height="13" VerticalAlignment="Center"/>
                            <TextBlock Text="测试" Margin="4,0,0,0" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnReset" Height="26" Padding="10,0"
                        Click="BtnReset_Click"
                        Background="#37474F" Foreground="#90A4AE" BorderThickness="0"
                        Cursor="Hand" ToolTip="重置为默认模板">
                        <StackPanel Orientation="Horizontal">
                            <icons:MaterialIcon Kind="Restore" Width="13" Height="13" VerticalAlignment="Center"/>
                            <TextBlock Text="重置" Margin="4,0,0,0" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 编辑器区 -->
        <avalonEdit:TextEditor
            x:Name="Editor"
            Grid.Row="1"
            FontFamily="Consolas, 'Courier New'"
            FontSize="13"
            Background="#1E1E2E"
            Foreground="#CDD6F4"
            LineNumbersForeground="#4A4A6A"
            ShowLineNumbers="True"
            WordWrap="False"
            Padding="4,4"/>

        <Rectangle Grid.Row="2" Fill="#2D2D3F"/>

        <!-- 测试面板 -->
        <Grid Grid.Row="3" Background="#181825">
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#2D2D3F" Padding="10,0">
                <DockPanel>
                    <icons:MaterialIcon Kind="TestTube" Width="13" Height="13"
                        Foreground="#90A4AE" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="测试输入 (HEX，如：01 02 03)" Foreground="#6C7086"
                        FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TestResultText" DockPanel.Dock="Right"
                        Foreground="#A6E3A1" FontSize="11" FontFamily="Consolas"
                        VerticalAlignment="Center" HorizontalAlignment="Right"
                        TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                </DockPanel>
            </Border>
            <Grid Grid.Row="1" Margin="8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TestInputBox" Grid.Column="0"
                    Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"
                    FontFamily="Consolas" FontSize="12" Padding="6,4"
                    Text="01 02 03 04"
                    VerticalContentAlignment="Top"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"/>
                <TextBox x:Name="TestOutputBox" Grid.Column="2"
                    Background="#1E1E2E" Foreground="#A6E3A1" BorderBrush="#313244"
                    FontFamily="Consolas" FontSize="12" Padding="6,4"
                    IsReadOnly="True"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Grid>

        <!-- 底部按钮 -->
        <Border Grid.Row="4" Background="#2D2D3F" Padding="14,0">
            <DockPanel>
                <TextBlock x:Name="StatusText" Foreground="#6C7086" FontSize="11"
                    VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Height="28" Width="80" Margin="0,0,10,0"
                        Click="BtnCancel_Click"
                        Background="#313244" Foreground="#CDD6F4" BorderThickness="0" Cursor="Hand">
                        取消
                    </Button>
                    <Button Height="28" Width="80"
                        Click="BtnSave_Click"
                        Background="#1565C0" Foreground="White" BorderThickness="0" Cursor="Hand">
                        保存
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
