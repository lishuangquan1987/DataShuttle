<UserControl
    x:Class="DataShuttle.WpfSample.Views.SetupView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:icons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:local="clr-namespace:DataShuttle.WpfSample.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:vm="clr-namespace:DataShuttle.WpfSample.ViewModels"
    Width="800"
    Height="450"
    d:DataContext="{d:DesignInstance vm:SetupViewModel}"
    Background="{DynamicResource RegionBrush}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" />


        <Grid Grid.Row="1">
            <Grid.Resources>
                <sys:Double x:Key="LabelWidth">110</sys:Double>
                <sys:Double x:Key="ValueWidth">150</sys:Double>
                <Style BasedOn="{StaticResource {x:Type Label}}" TargetType="Label">
                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="BorderThickness" Value="0" />
                </Style>
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="40" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Border
                Margin="5"
                BorderBrush="LightBlue"
                BorderThickness="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontWeight="Bold"
                        Text="左" />
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Text="数据传输方式：" />
                        <ComboBox
                            Grid.Column="1"
                            Height="30"
                            Margin="2"
                            ItemsSource="{Binding PluginNames}"
                            SelectedItem="{Binding ItemConfig.FromTransportConfig.Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                    <Grid Grid.Row="2">
                        <Grid
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding From串口ConfigVisibility}">
                            <StackPanel Orientation="Vertical">
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <Label
                                        Width="{StaticResource LabelWidth}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Right"
                                        Content="串口名称：" />
                                    <ComboBox
                                        Width="{StaticResource ValueWidth}"
                                        IsEditable="True"
                                        ItemsSource="{Binding SerialPorts}"
                                        Text="{Binding ItemConfig.FromTransportConfig.SerialPortTransportConfig.PortName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <Label
                                        Width="{StaticResource LabelWidth}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Right"
                                        Content="波特率：" />
                                    <TextBox Width="{StaticResource ValueWidth}" Text="{Binding ItemConfig.FromTransportConfig.SerialPortTransportConfig.BauRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <Label
                                        Width="{StaticResource LabelWidth}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Right"
                                        Content="奇偶校验：" />
                                    <ComboBox
                                        Width="{StaticResource ValueWidth}"
                                        ItemsSource="{Binding Parities}"
                                        SelectedItem="{Binding ItemConfig.FromTransportConfig.SerialPortTransportConfig.Parity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <Label
                                        Width="{StaticResource LabelWidth}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Right"
                                        Content="数据位：" />
                                    <TextBox Width="{StaticResource ValueWidth}" Text="{Binding ItemConfig.FromTransportConfig.SerialPortTransportConfig.DataBits}" />
                                </StackPanel>

                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <Label
                                        Width="{StaticResource LabelWidth}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Right"
                                        Content="停止位：" />
                                    <ComboBox
                                        Width="{StaticResource ValueWidth}"
                                        ItemsSource="{Binding StopBits}"
                                        SelectedItem="{Binding ItemConfig.FromTransportConfig.SerialPortTransportConfig.StopBits, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Grid
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding FromTcpClientConfigVisibility}">
                            <StackPanel Orientation="Vertical">
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <Label
                                        Width="{StaticResource LabelWidth}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Right"
                                        Content="连接的服务端IP：" />
                                    <TextBox Width="{StaticResource ValueWidth}" Text="{Binding ItemConfig.FromTransportConfig.TcpClientTransportConfig.ServerIp}" />
                                </StackPanel>
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <Label
                                        Width="{StaticResource LabelWidth}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Right"
                                        Content="连接的服务端端口：" />
                                    <TextBox Width="{StaticResource ValueWidth}" Text="{Binding ItemConfig.FromTransportConfig.TcpClientTransportConfig.ServerPort}" />
                                </StackPanel>

                            </StackPanel>
                        </Grid>

                        <Grid
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding FromTcpServerConfigVisibility}">
                            <StackPanel Orientation="Vertical">
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <Label
                                        Width="{StaticResource LabelWidth}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Right"
                                        Content="绑定IP：" />
                                    <TextBox Width="{StaticResource ValueWidth}" Text="{Binding ItemConfig.FromTransportConfig.TcpServerTransportConfig.BindingIp}" />
                                </StackPanel>
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <Label
                                        Width="{StaticResource LabelWidth}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Right"
                                        Content="绑定端口：" />
                                    <TextBox Width="{StaticResource ValueWidth}" Text="{Binding ItemConfig.FromTransportConfig.TcpServerTransportConfig.BindingPort}" />
                                </StackPanel>

                            </StackPanel>
                        </Grid>
                    </Grid>


                </Grid>
            </Border>


            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <icons:MaterialIcon
                    Margin="5"
                    FontSize="20"
                    Foreground="Blue"
                    Kind="ArrowLeftRight" />
            </StackPanel>


            <Border
                Grid.Column="2"
                Margin="5"
                BorderBrush="LightBlue"
                BorderThickness="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontWeight="Bold"
                        Text="右" />
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Text="数据传输方式：" />
                        <ComboBox
                            Grid.Column="1"
                            Height="30"
                            Margin="2"
                            ItemsSource="{Binding PluginNames}"
                            SelectedItem="{Binding ItemConfig.ToTransportConfig.Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                    <Grid Grid.Row="2">
                        <Grid
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding To串口ConfigVisibility}">
                            <StackPanel Orientation="Vertical">
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <Label
                                        Width="{StaticResource LabelWidth}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Right"
                                        Content="串口名称：" />
                                    <ComboBox
                                        Width="{StaticResource ValueWidth}"
                                        IsEditable="True"
                                        ItemsSource="{Binding SerialPorts}"
                                        Text="{Binding ItemConfig.ToTransportConfig.SerialPortTransportConfig.PortName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <Label
                                        Width="{StaticResource LabelWidth}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Right"
                                        Content="波特率：" />
                                    <TextBox Width="{StaticResource ValueWidth}" Text="{Binding ItemConfig.ToTransportConfig.SerialPortTransportConfig.BauRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <Label
                                        Width="{StaticResource LabelWidth}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Right"
                                        Content="奇偶校验：" />
                                    <ComboBox
                                        Width="{StaticResource ValueWidth}"
                                        ItemsSource="{Binding Parities}"
                                        SelectedItem="{Binding ItemConfig.ToTransportConfig.SerialPortTransportConfig.Parity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <Label
                                        Width="{StaticResource LabelWidth}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Right"
                                        Content="数据位：" />
                                    <TextBox Width="{StaticResource ValueWidth}" Text="{Binding ItemConfig.ToTransportConfig.SerialPortTransportConfig.DataBits}" />
                                </StackPanel>

                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <Label
                                        Width="{StaticResource LabelWidth}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Right"
                                        Content="停止位：" />
                                    <ComboBox
                                        Width="{StaticResource ValueWidth}"
                                        ItemsSource="{Binding StopBits}"
                                        SelectedItem="{Binding ItemConfig.ToTransportConfig.SerialPortTransportConfig.StopBits, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Grid
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding ToTcpClientConfigVisibility}">
                            <StackPanel Orientation="Vertical">
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <Label
                                        Width="{StaticResource LabelWidth}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Right"
                                        Content="连接的服务端IP：" />
                                    <TextBox Width="{StaticResource ValueWidth}" Text="{Binding ItemConfig.ToTransportConfig.TcpClientTransportConfig.ServerIp}" />
                                </StackPanel>
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <Label
                                        Width="{StaticResource LabelWidth}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Right"
                                        Content="连接的服务端端口：" />
                                    <TextBox Width="{StaticResource ValueWidth}" Text="{Binding ItemConfig.ToTransportConfig.TcpClientTransportConfig.ServerPort}" />
                                </StackPanel>

                            </StackPanel>
                        </Grid>

                        <Grid
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding ToTcpServerConfigVisibility}">
                            <StackPanel Orientation="Vertical">
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <Label
                                        Width="{StaticResource LabelWidth}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Right"
                                        Content="绑定IP：" />
                                    <TextBox Width="{StaticResource ValueWidth}" Text="{Binding ItemConfig.ToTransportConfig.TcpServerTransportConfig.BindingIp}" />
                                </StackPanel>
                                <StackPanel Margin="5" Orientation="Horizontal">
                                    <Label
                                        Width="{StaticResource LabelWidth}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Right"
                                        Content="绑定端口：" />
                                    <TextBox Width="{StaticResource ValueWidth}" Text="{Binding ItemConfig.ToTransportConfig.TcpServerTransportConfig.BindingPort}" />
                                </StackPanel>

                            </StackPanel>
                        </Grid>
                    </Grid>


                </Grid>
            </Border>

        </Grid>



        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Margin="5"
                Command="{Binding CancelCmd}"
                Style="{StaticResource ButtonDanger}">
                <StackPanel Orientation="Horizontal">
                    <icons:MaterialIcon Kind="Cancel" />
                    <TextBlock Margin="5,0,0,0" Text="取消" />
                </StackPanel>
            </Button>
            <Button
                Margin="5"
                Command="{Binding SureCmd}"
                Style="{StaticResource ButtonSuccess}">
                <StackPanel Orientation="Horizontal">
                    <icons:MaterialIcon Kind="Check" />
                    <TextBlock Margin="5,0,0,0" Text="确定" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
